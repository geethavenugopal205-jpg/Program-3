class Solution:
    def getMinDiff(self, arr, k):
        n = len(arr)
        if n == 1:
            return 0
        
        # Sort the array to find boundaries easily
        arr.sort()
        
        # Initial result: difference between max and min of the original array
        ans = arr[n-1] - arr[0]
        
        # Smallest possible height after increasing the shortest tower
        smallest = arr[0] + k
        # Largest possible height after decreasing the tallest tower
        largest = arr[n-1] - k
        
        for i in range(n - 1):
            # Potential min and max if we split at index i
            # arr[i] is the last element we increase
            # arr[i+1] is the first element we decrease
            
            curr_min = min(smallest, arr[i+1] - k)
            curr_max = max(largest, arr[i] + k)
            
            # Constraint: Resultant heights cannot be negative
            if curr_min < 0:
                continue
                
            # Update the answer if we found a smaller range
            ans = min(ans, curr_max - curr_min)
            
        return ans
        
        
